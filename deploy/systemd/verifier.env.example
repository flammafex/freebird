# Copy to /etc/freebird/verifier.env, chmod 0640, owned by root:freebird.
# Replace all example secrets and hostnames before starting the service.

RUST_LOG=info,freebird=debug
BIND_ADDR=127.0.0.1:8082
REQUIRE_TLS=true
BEHIND_PROXY=true

ADMIN_API_KEY=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
VERIFIER_ID=verifier:example:v4
VERIFIER_AUDIENCE=example
ISSUER_URL=https://issuer.example.org/.well-known/issuer
VERIFIER_SK_PATH=/var/lib/freebird/verifier/keys/issuer_sk.bin

REDIS_URL=redis://127.0.0.1:6379
REFRESH_INTERVAL_MIN=10
EPOCH_DURATION_SEC=86400
EPOCH_RETENTION=2
