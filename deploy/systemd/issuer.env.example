# Copy to /etc/freebird/issuer.env, chmod 0640, owned by root:freebird.
# Replace all example secrets and hostnames before starting the service.

RUST_LOG=info,freebird=debug
BIND_ADDR=127.0.0.1:8081
REQUIRE_TLS=true
BEHIND_PROXY=true

ADMIN_API_KEY=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
ISSUER_ID=issuer:example:v4
ISSUER_SK_PATH=/var/lib/freebird/issuer/keys/issuer_sk.bin
KEY_ROTATION_STATE_PATH=/var/lib/freebird/issuer/keys/key_rotation_state.json

PUBLIC_BEARER_ENABLE=true
PUBLIC_BEARER_SK_PATH=/var/lib/freebird/issuer/keys/public_bearer_sk.der
PUBLIC_BEARER_METADATA_PATH=/var/lib/freebird/issuer/keys/public_bearer_metadata.json

REDIS_URL=redis://127.0.0.1:6379
SYBIL_REPLAY_STORE=redis
SYBIL_REPLAY_REDIS_URL=redis://127.0.0.1:6379

SYBIL_RESISTANCE=invitation
SYBIL_INVITE_PERSISTENCE_PATH=/var/lib/freebird/issuer/state/invitations.json
SYBIL_INVITE_SIGNING_KEY_PATH=/var/lib/freebird/issuer/keys/invitation_signing_key.bin
SYBIL_INVITE_BOOTSTRAP_USERS=admin:100

# WebAuthn, when built with --features human-gate-webauthn
# SYBIL_RESISTANCE=webauthn
# WEBAUTHN_RP_ID=issuer.example.org
# WEBAUTHN_RP_ORIGIN=https://issuer.example.org
# WEBAUTHN_PROOF_SECRET=CHANGE_ME_RANDOM_SECRET
# WEBAUTHN_REDIS_URL=redis://127.0.0.1:6379
# WEBAUTHN_REQUIRE_ATTESTATION=true
# WEBAUTHN_ATTESTATION_POLICY=direct
# WEBAUTHN_ALLOWED_AAGUIDS=
